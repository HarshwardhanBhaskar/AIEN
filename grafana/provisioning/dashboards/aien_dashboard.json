      "id": 4,
      "title": "WAL Ledger Blocks Appended",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(aien_validator_ledger_blocks_total) by (type)",
          "legendFormat": "Blocks ({{type}})",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
